{
  "object_id": "crypto_alphafactory_method_v1",
  "created_at": "2026-05-19",
  "status": "gate_before_search",
  "purpose": "Define the crypto-specific AlphaFactory generator, reward, replay, and audit contract before any search.",
  "data_inputs": {
    "gold_panels": {
      "5m": "G:/AlphaFactory_CryptoData/gold/panels/crypto_core12_5m_v1.parquet",
      "1h": "G:/AlphaFactory_CryptoData/gold/panels/crypto_core12_1h_v1.parquet"
    },
    "sanity_report": "G:/AlphaFactory_CryptoData/gold/reports/crypto_core12_panel_v1_sanity.md",
    "feature_availability": "G:/AlphaFactory_CryptoData/gold/feature_availability/crypto_feature_availability_20260519.parquet"
  },
  "universe": {
    "primary": "core12 futures",
    "symbols": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT",
      "BNBUSDT",
      "XRPUSDT",
      "DOGEUSDT",
      "ADAUSDT",
      "LINKUSDT",
      "AVAXUSDT",
      "LTCUSDT",
      "BCHUSDT",
      "SUIUSDT"
    ],
    "spot_basis_scope": "core6 only; missing for non-core6 is expected and must not be filled cross-sectionally"
  },
  "temporal_splits": {
    "train": {
      "name": "train_2024",
      "start": "2024-01-01",
      "end": "2024-12-31T23:59:59Z"
    },
    "validation": {
      "name": "validation_2025H1",
      "start": "2025-01-01",
      "end": "2025-06-30T23:59:59Z"
    },
    "recent_oos": {
      "name": "recent_oos_2025H2_2026",
      "start": "2025-07-01",
      "end": "2026-04-30T23:59:59Z"
    }
  },
  "horizons": {
    "5m": [1, 3, 6, 12],
    "1h": [1, 3, 6, 12]
  },
  "generator_policy": {
    "source": "crypto native; CN stock FormulaGenV2/reward/replay files are reference only",
    "allowed_feature_families": [
      "price",
      "volatility",
      "liquidity",
      "taker_flow",
      "basis",
      "funding",
      "spot_basis_core6"
    ],
    "blocked_feature_families_for_historical_search": [
      "positioning_recent29d",
      "openInterestHist_recent29d",
      "globalLongShort_recent29d",
      "topLongShort_recent29d",
      "takerLongShort_recent29d"
    ],
    "initial_budget_prior_from_smoke": {
      "price_momentum_continuation": 0.35,
      "basis_premium_continuation": 0.25,
      "funding_state_interaction": 0.20,
      "volatility_state": 0.10,
      "liquidity_state": 0.05,
      "taker_flow_diagnostic": 0.05
    },
    "motif_requirements": [
      "motifs must be role-based, not random x/y token formulas",
      "5m and 1h candidates are separate evidence lanes",
      "spot_basis motifs must carry a core6 availability mask",
      "funding motifs must use latest_known_funding_rate and event-level z/persistence only",
      "positioning motifs are diagnostic/live-forward only until sufficient history accumulates"
    ]
  },
  "reward_policy": {
    "primary_metric": "multi-window oriented cross-sectional IC plus cluster-diversified long-short proxy",
    "required_windows": [
      "train_2024",
      "validation_2025H1",
      "recent_oos_2025H2_2026"
    ],
    "minimum_keep_conditions": {
      "validation_oriented_ic_positive": true,
      "recent_oos_oriented_ic_positive": true,
      "minimum_effective_dates": {
        "5m": 10000,
        "1h": 800
      },
      "no_single_symbol_dominance": true,
      "no_recent_only_positioning": true
    },
    "credit_components": {
      "validation_ic": 0.25,
      "recent_oos_ic": 0.30,
      "long_short_proxy": 0.20,
      "stability_across_windows": 0.15,
      "cluster_novelty": 0.10
    },
    "penalties": {
      "turnover_proxy": 0.15,
      "missing_availability_mask": "hard_reject",
      "same_bar_or_future_feature_use": "hard_reject",
      "label_column_use": "hard_reject",
      "positioning_historical_use": "hard_reject",
      "spot_basis_filled_outside_core6": "hard_reject",
      "one_window_only_success": "hold_research"
    }
  },
  "evaluation_stages": {
    "A0_feature_smoke": {
      "status": "completed",
      "report": "G:/AlphaFactory_CryptoData/alphafactory_crypto/reports/CRYPTO_ALPHA_SMOKE_V0_20260519.md"
    },
    "A1_generator_dry_run": {
      "status": "next",
      "description": "Generate crypto-native candidates with metadata only; no replay promotion."
    },
    "A2_strict_replay": {
      "status": "blocked_until_A1_passes",
      "description": "Evaluate candidates on fixed windows with leakage and availability gates."
    },
    "A3_cluster_registry": {
      "status": "blocked_until_A2_passes",
      "description": "Cluster by signal/return proxy; count unique deployable crypto clusters, not rows."
    }
  },
  "audit_policy": {
    "must_record": [
      "candidate_id",
      "expression",
      "interval",
      "horizon",
      "feature_families",
      "availability_mask",
      "feature_timestamp_rule",
      "label_start_rule",
      "train_metrics",
      "validation_metrics",
      "recent_oos_metrics",
      "turnover_proxy",
      "cluster_id",
      "decision"
    ],
    "decision_labels": [
      "KEEP_REPLAY_CANDIDATE",
      "HOLD_RESEARCH",
      "REJECT_LEAKAGE",
      "REJECT_RECENT_ONLY",
      "REJECT_UNSTABLE",
      "REJECT_DUPLICATE_CLUSTER"
    ]
  },
  "explicitly_not_allowed": [
    "Directly run CN stock reward weights on crypto panels",
    "Treat 5m and 1h as independent confirmations for the same formula without de-duplication",
    "Use fwd_ret_* columns as generator inputs",
    "Use same-bar funding, positioning, or close information to predict the same bar",
    "Backfill recent29d positioning into 2024-2026 historical search"
  ]
}
